# ============================================================
# juste-des-ventilateurs -- configuration d'environnement
# Copier vers .env et adapter selon votre installation
# ============================================================

# --- jumeaux-chauds : API REST ---
API_BASE_URL=http://localhost:8000
# Sous Docker Desktop Windows, remplacer localhost par :
# API_BASE_URL=http://host.docker.internal:8000

# --- jumeaux-chauds : broker MQTT ---
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
# Sous Docker Desktop Windows :
# MQTT_BROKER_HOST=host.docker.internal

# Identifiant du cluster (doit correspondre aux topics MQTT)
CLUSTER_ID=cluster_alpha

# Racine des topics MQTT (dt/{cluster}/{machine}/telemetry)
MQTT_TOPIC_ROOT=dt

# --- Superviseur : boucle de decision ---
# Nombre de ticks simules entre deux decisions (1 tick = 1s simulee)
# A 5 : decision toutes les 5s simulees, quelle que soit la vitesse reelle
DECISION_INTERVAL_TICKS=5

# Intervalle REST fallback (secondes reelles) -- utilise si MQTT indisponible
DECISION_INTERVAL_S=5

# Seuil de risque a partir duquel une action de controle est declenchee
RISK_THRESHOLD=0.6

# Seuil minimal pour logguer l'etat d'une machine (evite le bruit a faible risque)
RISK_LOG_THRESHOLD=0.05

# --- Superviseur : modeles ---
SUPERVISOR_MODE=ml
PREDICTOR_MODEL=gradient_boosting
CONTROLLER_MODEL=score_controller

# Label cible pour le predicteur de pannes
FAILURE_LABEL=failure_60s

# --- Stockage des donnees ---
STORAGE_BACKEND=parquet
PARQUET_DATA_DIR=./data

# TimescaleDB (optionnel, profil storage)
# TIMESCALEDB_URL=postgresql://user:pass@localhost:5432/telemetry

# --- Feature engineering ---
T_SHUTDOWN_DEFAULT_C=88.0
ROLLING_WINDOW_S=60
